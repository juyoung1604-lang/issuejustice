{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/issues/layout,_N_T_/issues/latest/layout,_N_T_/issues/latest/page,_N_T_/issues/latest"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/issues/latest/__PAGE__",
    "/issues/latest",
    "/issues",
    "/_index",
    "/_head"
  ]
}