{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/ranking/layout,_N_T_/ranking/page,_N_T_/ranking"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/ranking/__PAGE__",
    "/ranking",
    "/_index",
    "/_head"
  ]
}